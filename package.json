{
	"name": "intrepid-ibex",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --write . && eslint . --fix",
		"format": "prettier --write .",
		"test": "vitest",
		"test:unit": "npm run test -- --run",
		"cf:preview": "pnpm build && wrangler pages dev build",
		"cf:deploy": "pnpm build && wrangler pages deploy build"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/ubuntu-sans": "^5.2.10",
		"@fontsource/ubuntu-mono": "^5.2.8",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"eslint": "^10.4.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"fake-indexeddb": "^6.2.5",
		"globals": "^17.4.0",
		"mdsvex": "^0.12.7",
		"playwright": "^1.60.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0",
		"wrangler": "^4.99.0"
	},
	"dependencies": {
		"@atcute/atproto": "^4.0.2",
		"@atcute/bluesky": "^4.0.7",
		"@atcute/client": "^5.0.0",
		"@atcute/lexicons": "^2.0.0",
		"@fontsource/ubuntu": "^5.2.8",
		"@resvg/resvg-js": "^2.6.2",
		"@shikijs/core": "^4.2.0",
		"@shikijs/engine-javascript": "^4.2.0",
		"@shikijs/langs": "^4.2.0",
		"dexie": "^4.4.3",
		"flexsearch": "^0.8.212",
		"satori": "^0.26.0",
		"satori-html": "^0.3.2",
		"shiki": "^4.2.0"
	}
}
